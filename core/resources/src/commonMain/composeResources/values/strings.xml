    <!-- ============================================================ -->
    <!-- Onboarding                                                   -->
    <!-- ============================================================ -->
    <string name="onboarding_intro_title">Hi.</string>
    <string name="onboarding_intro_body_1">I\'m Undercurrent. A small, private assistant that lives on this phone. I\'ll help you think, write, remember — quietly, without sending your conversations anywhere they don\'t need to go.</string>
    <string name="onboarding_intro_body_2">I work best when you bring your own provider — Anthropic, OpenAI, OpenRouter, DeepSeek. You\'ll paste a key in a minute. Until then, this is just paper.</string>
    <string name="onboarding_memory_title">Memory you can see.</string>
    <string name="onboarding_memory_body_1">If I remember something about you — a project name, a preference, a way you like to be addressed — it\'ll show up in Memories. Delete any of it. Wipe all of it.</string>
    <string name="onboarding_memory_body_2">Conversations, traces, costs. Everything I\'ve done is browsable. Nothing\'s hidden, nothing leaves.</string>
    <string name="onboarding_persona_title">Pick a voice.</string>
    <string name="onboarding_persona_body">Choose how I sound. Default works for most things — pick another if you\'d like a particular register. You can change this anytime in Personas.</string>
    <string name="onboarding_provider_title">One last thing.</string>
    <string name="onboarding_provider_body">Pick where the model lives. You can change this later — each provider keeps its own key on this device.</string>
    <string name="onboarding_cta_begin">Begin reading →</string>
    <string name="onboarding_cta_lets_go">Let\'s go →</string>
    <string name="onboarding_cta_continue">Keep going →</string>
    <string name="onboarding_helper_intro">Nothing happens until you tap.</string>
    <string name="onboarding_helper_persona_selected">· %1$s selected</string>
    <string name="onboarding_helper_provider_selected">· %1$s selected</string>
    <string name="onboarding_voice_label">VOICE</string>
    <string name="onboarding_provider_label">PROVIDER</string>
    <string name="onboarding_keys_privacy">Keys live on this device. Nothing else.</string>
